generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ai_insights {
  id                BigInt             @id @default(autoincrement())
  title             String?            @db.VarChar(255)
  description       String?
  priority          String?            @db.VarChar(20)
  generated_at      DateTime?          @default(now()) @db.Timestamp(6)
  forecast_id       BigInt?
  revenue_forecasts revenue_forecasts? @relation(fields: [forecast_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model approval_requests {
  id                                          BigInt    @id @default(autoincrement())
  request_type                                String?   @db.VarChar(30)
  reference_id                                BigInt?
  status                                      String?   @db.VarChar(20)
  requested_by                                BigInt?
  approved_by                                 BigInt?
  notes                                       String?
  created_at                                  DateTime? @default(now()) @db.Timestamp(6)
  users_approval_requests_approved_byTousers  users?    @relation("approval_requests_approved_byTousers", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_approval_requests_requested_byTousers users?    @relation("approval_requests_requested_byTousers", fields: [requested_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model bundles {
  id                               BigInt       @id @default(autoincrement())
  name                             String?      @db.VarChar(255)
  description                      String?
  bundle_price                     Decimal?     @db.Decimal(12, 2)
  status                           String?      @db.VarChar(20)
  created_by                       BigInt?
  approved_by                      BigInt?
  created_at                       DateTime?    @default(now()) @db.Timestamp(6)
  image_url                        String?
  users_bundles_approved_byTousers users?       @relation("bundles_approved_byTousers", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_bundles_created_byTousers  users?       @relation("bundles_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sale_items                       sale_items[]
}

model categories {
  id         BigInt     @id @default(autoincrement())
  name       String     @db.VarChar(100)
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  products   products[]
}

model chatbot_logs {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt?
  question   String
  answer     String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model datasets {
  id          BigInt    @id @default(autoincrement())
  file_name   String?   @db.VarChar(255)
  uploaded_by BigInt?
  uploaded_at DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model events {
  id           BigInt    @id @default(autoincrement())
  name         String?   @db.VarChar(255)
  event_date   DateTime? @db.Date
  event_type   String?   @db.VarChar(50)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  start_date   DateTime? @db.Date
  end_date     DateTime? @db.Date
  impact_score Int?      @default(1)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory_logs {
  id              BigInt         @id @default(autoincrement())
  product_size_id BigInt?
  movement_type   String?        @db.VarChar(20)
  quantity        Int
  notes           String?
  created_at      DateTime?      @default(now()) @db.Timestamp(6)
  product_sizes   product_sizes? @relation(fields: [product_size_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model product_sizes {
  id             BigInt           @id @default(autoincrement())
  product_id     BigInt
  size_name      String           @db.VarChar(10)
  selling_price  Decimal          @db.Decimal(12, 2)
  cost_price     Decimal?         @db.Decimal(12, 2)
  current_stock  Int?             @default(0)
  minimum_stock  Int?             @default(10)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  inventory_logs inventory_logs[]
  products       products         @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sale_items     sale_items[]
}

model products {
  id            BigInt          @id @default(autoincrement())
  category_id   BigInt?
  name          String          @db.VarChar(150)
  description   String?
  is_active     Boolean?        @default(true)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  product_sizes product_sizes[]
  categories    categories?     @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sale_items    sale_items[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model promotions {
  id                                  BigInt    @id @default(autoincrement())
  title                               String    @db.VarChar(255)
  description                         String?
  discount_percent                    Decimal?  @db.Decimal(5, 2)
  start_date                          DateTime? @db.Date
  end_date                            DateTime? @db.Date
  status                              String?   @db.VarChar(20)
  created_by                          BigInt?
  approved_by                         BigInt?
  created_at                          DateTime? @default(now()) @db.Timestamp(6)
  image_url                           String?
  users_promotions_approved_byTousers users?    @relation("promotions_approved_byTousers", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_promotions_created_byTousers  users?    @relation("promotions_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales                               sales[]
}

model revenue_forecasts {
  id                BigInt        @id @default(autoincrement())
  forecast_date     DateTime?     @db.Date
  predicted_revenue Decimal?      @db.Decimal(12, 2)
  confidence_score  Decimal?      @db.Decimal(5, 2)
  created_at        DateTime?     @default(now()) @db.Timestamp(6)
  ai_insights       ai_insights[]
}

model sale_items {
  id              BigInt         @id @default(autoincrement())
  sale_id         BigInt?
  product_id      BigInt?
  product_size_id BigInt?
  quantity        Int
  unit_price      Decimal        @db.Decimal(12, 2)
  subtotal        Decimal        @db.Decimal(12, 2)
  bundle_id       BigInt?
  bundles         bundles?       @relation(fields: [bundle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products        products?      @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product_sizes   product_sizes? @relation(fields: [product_size_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales           sales?         @relation(fields: [sale_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model sales {
  id               BigInt       @id @default(autoincrement())
  transaction_date DateTime     @db.Timestamp(6)
  total_amount     Decimal      @db.Decimal(12, 2)
  created_at       DateTime?    @default(now()) @db.Timestamp(6)
  payment_method   String?      @db.VarChar(30)
  total_items      Int?         @default(0)
  promotion_id     BigInt?
  sale_items       sale_items[]
  promotions       promotions?  @relation(fields: [promotion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id                                                      BigInt              @id @default(autoincrement())
  name                                                    String              @db.VarChar(100)
  email                                                   String              @unique @db.VarChar(150)
  password                                                String              @db.VarChar(255)
  role                                                    String              @db.VarChar(20)
  created_at                                              DateTime?           @default(now()) @db.Timestamp(6)
  last_login                                              DateTime?           @db.Timestamp(6)
  approval_requests_approval_requests_approved_byTousers  approval_requests[] @relation("approval_requests_approved_byTousers")
  approval_requests_approval_requests_requested_byTousers approval_requests[] @relation("approval_requests_requested_byTousers")
  bundles_bundles_approved_byTousers                      bundles[]           @relation("bundles_approved_byTousers")
  bundles_bundles_created_byTousers                       bundles[]           @relation("bundles_created_byTousers")
  chatbot_logs                                            chatbot_logs[]
  datasets                                                datasets[]
  promotions_promotions_approved_byTousers                promotions[]        @relation("promotions_approved_byTousers")
  promotions_promotions_created_byTousers                 promotions[]        @relation("promotions_created_byTousers")
}
